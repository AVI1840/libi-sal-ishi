# ===========================================
# LIBI — Sal Ishi For You
# Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Environment
ENVIRONMENT=development  # development | staging | production

# ===========================================
# Database Configuration
# ===========================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/libi_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ===========================================
# Redis Configuration (Session Storage)
# ===========================================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ===========================================
# JWT Authentication
# ===========================================
JWT_SECRET_KEY=replace-with-a-random-secret-min-32-characters-long
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===========================================
# Cloud Provider Configuration
# ===========================================
# Options: aws | gcp | azure
CLOUD_PROVIDER=gcp

# AWS Configuration (if CLOUD_PROVIDER=aws)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
AWS_S3_BUCKET=libi-storage

# GCP Configuration (if CLOUD_PROVIDER=gcp)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
GCP_PROJECT_ID=libi-ai
GCP_STORAGE_BUCKET=libi-storage

# Azure Configuration (if CLOUD_PROVIDER=azure)
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=libi-storage

# ===========================================
# LLM Provider Configuration
# ===========================================
# Primary provider: anthropic | openai | google
LLM_PROVIDER=anthropic
LLM_MODEL=claude-3-5-sonnet-20241022

# Fallback provider (optional)
LLM_FALLBACK_PROVIDER=openai
LLM_FALLBACK_MODEL=gpt-4o

# API Keys — replace with your own keys
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
GOOGLE_API_KEY=your-google-api-key-here

# LLM Settings
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7

# ===========================================
# TTS (Text-to-Speech) Configuration
# ===========================================
# Options: google | elevenlabs
TTS_PROVIDER=google

# Google TTS
GOOGLE_TTS_API_KEY=

# ElevenLabs (premium)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# TTS Settings
TTS_LANGUAGE=he-IL
TTS_VOICE=he-IL-Wavenet-A
TTS_SPEAKING_RATE=0.85  # Slower for elderly

# ===========================================
# Vector Store (Semantic Memory)
# ===========================================
# Options: pinecone | pgvector
VECTOR_STORE_PROVIDER=pinecone

# Pinecone
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX=libi-memories

# ===========================================
# AI Agent Specific
# ===========================================
# Safety
EMERGENCY_PHONE=101  # Israeli emergency
ENABLE_EMERGENCY_DETECTION=true
ENABLE_COGNITIVE_MONITORING=true

# Conversation
MAX_CONVERSATION_HISTORY=50
SENTIMENT_ALERT_THRESHOLD=-0.5

# ===========================================
# Marketplace Specific
# ===========================================
# Payment gateway (mock for MVP)
PAYMENT_GATEWAY=mock  # mock | tranzila | payplus

# Business rules
PLATFORM_FEE_PERCENT=7
UNIT_VALUE_NIS=120
MIN_OPTIMAL_AGING_UNITS=2
UNITS_EXPIRY_DAYS=90

# ===========================================
# Service URLs (for inter-service communication)
# ===========================================
AI_AGENT_URL=http://localhost:8001
MARKETPLACE_URL=http://localhost:8002
INTEGRATION_URL=http://localhost:8003

# ===========================================
# Logging & Monitoring
# ===========================================
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json  # json | text

# Sentry (optional)
SENTRY_DSN=

# ===========================================
# CORS Configuration
# ===========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
